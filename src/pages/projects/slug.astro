---
import { getCollection, getEntry } from 'astro:content';
import '../../styles/projects.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const entry = await getEntry('projects', slug!);
const { Content } = await entry!.render();
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{entry!.data.title}</title>
  <!-- model-viewer only loads on pages that actually use a model;
       the import is cheap and the component lazy-loads the WASM/3D itself -->
  <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>
</head>
<body>
  <!-- The drawer fetches THIS element's innerHTML for the in-place swap.
       Keep the marker attribute. -->
  <main data-project-content>
    <h1>{entry!.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </main>
</body>
</html>