---
import { getCollection, getEntry, render } from 'astro:content';
import '../../styles/projects.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  // Astro 6: entry.id is now the slug.
  return projects.map((p) => ({ params: { slug: p.id } }));
}

const { slug } = Astro.params;
const entry = await getEntry('projects', slug!);
// Astro 6: render() is a standalone import, not entry.render().
const { Content } = await render(entry!);
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{entry!.data.title}</title>
  <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>
</head>
<body>
  <!-- The drawer fetches THIS element's innerHTML for the in-place swap.
       Keep the marker attribute. -->
  <main data-project-content>
    <h1>{entry!.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </main>
</body>
</html>